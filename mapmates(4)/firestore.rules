rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ==========================================
    // PILLAR 3: PRIMITIVE DEFINITIONS
    // ==========================================
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { 
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email_verified == null); 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        // Highly recommended: Replace with your actual Firebase UID(s)
        request.auth.uid in ['YOUR_REAL_FIREBASE_UID'] || 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }

    // ==========================================
    // PILLAR 2: VALIDATION HELPERS
    // ==========================================
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'email']) &&
             data.uid == request.auth.uid &&
             data.username is string && data.username.size() <= 50;
    }

    // ==========================================
    // RULES
    // ==========================================

    match /admins/{uid} {
      allow get: if isSignedIn();
      allow write: if isAdmin();
    }

    match /userLabelStats/{userId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) || isAdmin();
      
      match /friends/{friendId} {
        allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
        allow list: if isSignedIn(); 
        allow write: if isOwner(userId) || isAdmin();
      }
      
      match /likes/{likeId} {
        allow get, list: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /views/{viewId} {
        allow get, list: if isSignedIn();
        allow write: if isSignedIn();
      }

      match /path_points/{pointId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    match /destinies/{destinyId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow update, delete: if isSignedIn() && (existing().uid == request.auth.uid || isAdmin());
    }

    match /labels/{labelId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && (
        incoming().userId == request.auth.uid || 
        incoming().uid == request.auth.uid || 
        incoming().creatorId == request.auth.uid ||
        isAdmin()
      );
      allow update, delete: if isSignedIn() && (
        existing().userId == request.auth.uid || 
        existing().uid == request.auth.uid || 
        existing().creatorId == request.auth.uid ||
        isAdmin()
      );
    }

    match /help_signals/{signalId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow delete: if isSignedIn() && (existing().uid == request.auth.uid || isAdmin());
    }

    match /moments/{momentId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow delete: if isSignedIn() && (existing().uid == request.auth.uid || isAdmin());
    }

    match /conversations/{convId} {
      allow get, list: if isSignedIn() && (request.auth.uid in existing().participants);
      allow create: if isSignedIn() && (request.auth.uid in incoming().participants);
      allow update: if isSignedIn() && (request.auth.uid in existing().participants);
      
      match /messages/{messageId} {
        allow get, list: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants);
        allow write: if isSignedIn() && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants);
      }
    }

    match /friendRequests/{requestId} {
      allow get: if isSignedIn() && (request.auth.uid in resource.data.participants || existing().from == request.auth.uid || existing().to == request.auth.uid);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && incoming().from == request.auth.uid;
      allow update, delete: if isSignedIn() && (request.auth.uid in existing().participants || existing().from == request.auth.uid || existing().to == request.auth.uid);
    }

    match /notifications/{notifId} {
      allow get: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && incoming().uid is string;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /history/{historyId} {
      allow get: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /ratings/{ratingId} {
      allow read, write: if isSignedIn();
    }

    match /flash_sales/{saleId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /app_config/{configId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /userFeatureStats/{statId} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /parentChildPaths/{pathId} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /destinyConfigs/{configId} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /calls/{callId} {
      allow get, list: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /test/{docId} {
      allow read, write: if isSignedIn();
    }

    // ==========================================
    // PILLAR 0: GLOBAL SAFETY NET
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
