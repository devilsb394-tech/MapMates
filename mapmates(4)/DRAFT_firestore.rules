rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // P3: PRIMITIVES & HELPERS
    // ==========================================
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\.\\@\\:\\~\\|]+$');
    }

    function isAdmin() {
      // Bootstrapped Admin: User email from runtime
      return isSignedIn() && (
        request.auth.token.email == 'devilsb394@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isStringSafe(val, max) {
      return val is string && val.size() <= max;
    }

    function isTimestampSafe(val) {
      return val is timestamp || (val is string && val.size() <= 64);
    }

    // ==========================================
    // P2: VALIDATION BLUEPRINTS
    // ==========================================

    function isValidUser(data, isCreate) {
      return (isCreate ? data.keys().hasAll(['uid', 'username', 'email', 'profession']) : true) &&
             (data.uid == null || data.uid == request.auth.uid) &&
             (data.username == null || isStringSafe(data.username, 50)) &&
             (data.email == null || isStringSafe(data.email, 100)) &&
             (data.profession == null || isStringSafe(data.profession, 100));
    }

    function isValidNotification(data, isCreate) {
      return (isCreate ? data.keys().hasAll(['uid', 'fromId', 'type', 'read', 'timestamp']) : true) &&
             (data.uid == null || isStringSafe(data.uid, 128)) &&
             (data.fromId == null || isStringSafe(data.fromId, 128)) &&
             (data.type == null || data.type in ['message', 'friend_request', 'like', 'rate', 'help']) &&
             (data.read == null || data.read is bool) &&
             (data.timestamp == null || isTimestampSafe(data.timestamp));
    }

    function isValidMessage(data, isCreate) {
      return (isCreate ? data.keys().hasAll(['senderId', 'receiverId', 'text', 'timestamp']) : true) &&
             (data.senderId == null || data.senderId == request.auth.uid) &&
             (data.text == null || isStringSafe(data.text, 5000)) &&
             (data.timestamp == null || isTimestampSafe(data.timestamp));
    }

    function isValidHistory(data, isCreate) {
      return (isCreate ? data.keys().hasAll(['uid', 'type', 'timestamp']) : true) &&
             (data.uid == null || data.uid == request.auth.uid) &&
             (data.type == null || data.type in ['search', 'view']) &&
             (data.timestamp == null || isTimestampSafe(data.timestamp));
    }

    // ==========================================
    // P0: GLOBAL SAFETY NET
    // ==========================================
    
    match /{document=**} {
      allow read, write: if false;
    }

    // Public Paths
    match /test/connection {
      allow read: if isSignedIn(); 
      allow write: if isAdmin();
    }

    match /app_config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ==========================================
    // COLLECTIONS
    // ==========================================

    // User Profiles
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      // Pillar 8: Enforce UID filter in list
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid; 
      // Directory listing allowed if PII is protected (using get is better for profiles)
      // Allow list for discoverability if not private
      allow list: if isSignedIn() && resource.data.privateProfile == false;

      allow create: if isValidId(userId) && isOwner(userId) && isValidUser(incoming(), true);
      allow update: if (isOwner(userId) || isAdmin()) && 
                    isValidUser(incoming(), false) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['username', 'photoURL', 'bio', 'gender', 'religion', 'language', 'age', 'relationshipStatus', 'profession', 'economicClass', 'location', 'isOnline', 'lastSeen', 'mood', 'lastMoodUpdate', 'currentMood', 'stats', 'business', 'recentPath', 'showOnMap', 'privateProfile', 'showOnDiscover']);
      allow delete: if (isOwner(userId) || isAdmin());

      match /views/{viewId} {
        allow read: if isSignedIn() && isValidId(viewId);
        allow create: if isSignedIn() && viewId == request.auth.uid && isValidId(viewId);
      }
      match /likes/{likeId} {
        allow read: if isSignedIn() && isValidId(likeId);
        allow create: if isSignedIn() && likeId == request.auth.uid && isValidId(likeId);
        allow delete: if isSignedIn() && likeId == request.auth.uid;
      }
      match /friends/{friendId} {
        allow read: if isSignedIn() && (isOwner(userId) || isOwner(friendId)) && isValidId(friendId);
        allow write: if (isOwner(userId) || isOwner(friendId) || isAdmin()) && isValidId(friendId);
      }
      match /path_points/{pointId} {
        allow read: if isSignedIn() && isOwner(userId) && isValidId(pointId);
        allow create: if isOwner(userId) && isValidId(pointId);
      }
    }

    match /notifications/{notifId} {
      allow get: if isSignedIn() && isValidId(notifId) && resource.data.uid == request.auth.uid;
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isVerified() && isValidNotification(incoming(), true) && incoming().fromId == request.auth.uid;
      allow update: if isOwner(existing().uid) && isValidNotification(incoming(), false) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(existing().uid);
    }

    match /conversations/{convId} {
      function isParticipant(participants) {
        return request.auth.uid in participants;
      }

      allow get: if isSignedIn() && isValidId(convId) && isParticipant(resource.data.participants);
      allow list: if isSignedIn() && isParticipant(resource.data.participants);
      allow create: if isSignedIn() && isValidId(convId) && isParticipant(incoming().participants);
      allow update: if isSignedIn() && isParticipant(existing().participants);

      match /messages/{messageId} {
        allow get: if isSignedIn() && isValidId(messageId) && isParticipant(get(/databases/$(database)/documents/conversations/$(convId)).data.participants);
        allow list: if isSignedIn() && isParticipant(get(/databases/$(database)/documents/conversations/$(convId)).data.participants);
        allow create: if isSignedIn() && isValidId(messageId) && isValidMessage(incoming(), true) && isParticipant(get(/databases/$(database)/documents/conversations/$(convId)).data.participants);
      }
    }

    match /history/{historyId} {
      allow get: if isOwner(resource.data.uid);
      allow list: if isOwner(resource.data.uid) && request.query.limit <= 100;
      allow create: if isValidHistory(incoming(), true) && isOwner(incoming().uid);
      allow delete: if isOwner(existing().uid);
    }

    match /moments/{momentId} {
      allow read: if isSignedIn() && isValidId(momentId);
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow delete: if isOwner(existing().uid) || isAdmin();
    }

    match /help_signals/{signalId} {
      allow read: if isSignedIn() && isValidId(signalId);
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow delete: if isOwner(existing().uid) || isAdmin();
    }

    match /destinies/{destinyId} {
      allow read: if isSignedIn() && isValidId(destinyId);
      allow create: if isSignedIn() && incoming().uid == request.auth.uid;
      allow update: if isOwner(existing().uid) || isAdmin();
      allow delete: if isOwner(existing().uid) || isAdmin();
    }

    match /friendRequests/{requestId} {
      allow get: if isSignedIn() && isValidId(requestId) && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
      allow list: if isSignedIn() && resource.data.participants.hasAny([request.auth.uid]);
      allow create: if isSignedIn() && isValidId(requestId) && incoming().from == request.auth.uid;
      allow update: if isSignedIn() && (existing().from == request.auth.uid || existing().to == request.auth.uid);
      allow delete: if isSignedIn() && (existing().from == request.auth.uid || existing().to == request.auth.uid || isAdmin());
    }

    // Default catch-all for any other collections
    match /{collection}/{docId} {
      allow read: if isSignedIn() && isAdmin();
      allow write: if isSignedIn() && isAdmin();
    }
  }
}
